{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://prithivi-backend.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://prithivi-backend.onrender.com/uploads/:path*"
    },
    { "source": "/((?!api|uploads|assets|favicon).*)", "destination": "/index.html" }
  ]
}
